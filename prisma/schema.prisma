generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  passwordHash  String
  role          UserRole       @default(LINE_REPRESENTATIVE)
  line          LineType?
  positionTitle String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  announcements Announcement[]
  auditLogs     AuditLog[]
  news          News[]         @relation("NewsAuthor")
  profiles      Profile[]
}

model Profile {
  id                     String          @id @default(cuid())
  userId                 String
  line                   LineType
  title                  String
  fullTraditionalName    String
  currentPosition        String
  biography              String
  familyHistory          String
  achievements           String
  palaceResponsibilities String
  profilePictureUrl      String?
  status                 ProfileStatus   @default(PENDING_REVIEW)
  reviewNote             String?
  reviewedAt             DateTime?
  reviewedById           String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  currentOccupation      String?
  dateOfBirth            String?
  expertiseInterest      String?
  familyCompound         String?
  familyVillage          String?
  fieldSpecialization    String?
  highestQualification   String?
  languagesSpoken        String?
  localGovernment        String?
  otherQualifications    String?
  yearInstalled          String?
  yearInstalledAsMagaji  String?
  yearPromotedLine       String?
  documents              DocumentAsset[]
  media                  MediaAsset[]
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([line, status])
  @@index([userId])
}

model News {
  id               String        @id @default(cuid())
  headline         String
  subtitle         String?
  content          String
  featuredImageUrl String?
  authorId         String?
  authorName       String?
  publishDate      DateTime?
  category         NewsCategory
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  author           User?         @relation("NewsAuthor", fields: [authorId], references: [id])

  @@index([status, publishDate])
  @@index([category])
}

model GalleryItem {
  id          String          @id @default(cuid())
  title       String
  description String?
  url         String
  type        MediaType       @default(IMAGE)
  category    GalleryCategory
  status      ContentStatus   @default(PUBLISHED)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category, status])
}

model MediaAsset {
  id        String    @id @default(cuid())
  profileId String?
  title     String?
  url       String
  type      MediaType @default(IMAGE)
  createdAt DateTime  @default(now())
  profile   Profile?  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model DocumentAsset {
  id        String   @id @default(cuid())
  profileId String
  title     String
  url       String
  createdAt DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model StreamSetting {
  id          String     @id @default(cuid())
  type        StreamType @unique
  title       String
  streamUrl   String
  embedUrl    String?
  isActive    Boolean    @default(false)
  description String?
  updatedAt   DateTime   @updatedAt
  createdAt   DateTime   @default(now())
}

model Announcement {
  id        String        @id @default(cuid())
  title     String
  content   String
  status    ContentStatus @default(DRAFT)
  authorId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  author    User?         @relation(fields: [authorId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId])
}

enum UserRole {
  SUPER_ADMIN
  LINE_REPRESENTATIVE
}

enum LineType {
  OTUN
  BALOGUN
  MOGAJI
  BAALE
  IYALODE
  ADVISORY_COUNCIL
  HONORARY
}

enum ProfileStatus {
  PENDING_REVIEW
  REQUEST_CHANGES
  PUBLISHED
  REJECTED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NewsCategory {
  PALACE_NEWS
  TRADITIONAL_COUNCIL
  CULTURAL_EVENTS
  GOVERNMENT_RELATIONS
}

enum GalleryCategory {
  CORONATION
  FESTIVALS
  PALACE_EVENTS
  HISTORICAL_ARCHIVES
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum StreamType {
  RADIO
  VIDEO
}
